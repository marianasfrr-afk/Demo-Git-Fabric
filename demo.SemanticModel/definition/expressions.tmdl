	annotation PBI_ResultType = Function

expression 'DirectQuery para AS – demo_git_direct_lake' =
		let
		    Source = AnalysisServices.Database("powerbi://api.powerbi.com/v1.0/myorg/demo_git_fabric_dev", "demo_git_direct_lake"),
		    Cubes = Table.Combine(Source[Data]),
		    Cube = Cubes{[Id="Model", Kind="Cube"]}[Data]
		in
		    Cube
