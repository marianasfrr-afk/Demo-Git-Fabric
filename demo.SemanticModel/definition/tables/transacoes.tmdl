	measure 'Valor Total' = SUM(transacoes[Total])
		displayFolder: Medidas
		lineageTag: 05f44967-7101-4170-a244-7a43ec1d94a9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column ID
		dataType: double
